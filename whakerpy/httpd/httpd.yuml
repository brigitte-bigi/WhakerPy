// -------------------
// Class descriptions
// -------------------

// Class to bake an HTML response page.
// Intent to be used as base class for any html page.
[BaseResponseRecipe|+name:str;+page:str;+status:int;+tree:HTMLTree|+bake(events);-process_events(events);]
[sppasHTTPDStatus|+code:int;]
[sppasBaseHTTPDServer|-pages:dict;-default:str;]
[sppasHTTPDHandler]

// -------------------
// Class relations
// -------------------

[BaseResponseRecipe]-1>[HTMLTree]
[BaseResponseRecipe]-1>[sppasHTTPDStatus]

