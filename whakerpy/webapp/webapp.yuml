// -------------------
// Class descriptions
// -------------------

[WebSiteData|~main_path:str;~default:str]
[WebSiteApplication|-server: BaseHTTPServer;-port: int;-location: str]
[WebSiteResponse]
[WSGIApplication|-default_path:str;-default_file:str;~pages:dict]

// -------------------
// Class relations
// -------------------

[WebSiteApplication]->[HTTPDHandler {bg:purple}]

[WebSiteData]->[WebSiteResponse]

[BaseResponseRecipe {bg:purple}]^[WebSiteResponse]

[WSGIApplication]->[WebSiteData]
[WSGIApplication]-n>[WebSiteResponse]
[WSGIApplication]->[HTTPDHandlerUtils {bg:purple}]
