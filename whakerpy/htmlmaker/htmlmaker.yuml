// Or try with: https://github.com/jaime-olivares/yuml-diagram

// -------------------
// Class descriptions
// -------------------

// An HTML page is a tree of nodes.
// The root has 2 children: the head and the body
[HTMLTree|-id:str;-body:HTMLNode;+head:HTMLHeadNode;+body_header:HTMLNode,;+body_nav:HTMLNode;+body_main:HTMLNode;+body_footer:HTMLNode;+body_script:HTMLNode|serialize_to_file()]

// A Node of an HTML tree
[BaseNode|identifier: str; parent: BaseNode|is_leaf();is_root();get_parent();set_parent();serialize()]
[BaseTagNode|tag: str; attributes: dict|get_tag()|has_attribute(k);set_attribute(k,v);add_attribute(k,v);remove_attribute(k);serialize()]
[TagNode|children:list;value:str|get_child(id);has_child(id);append_child(node);insert_child(pos,node);remove_child(id);pop_child(pos)|set_value(v)]
[HTMLHeadNode|title();meta();script();link();css()]

// -------------------
// Class relations
// -------------------

[HTMLComment]^[BaseNode]
[Doctype]^[BaseNode]
[TagNode]^[BaseNode]

[BaseTagNode]^[BaseNode]
[EmptyNode]^[BaseTagNode]
[HTMLImage]^[EmptyNode]
[HTMLInputText]^[EmptyNode]
[HTMLBr]^[EmptyNode]
[HTMLHr]^[EmptyNode]

[HTMLNode]^[TagNode]

[HTMLHeadNode]^[HTMLNode]
[HTMLButton]^[HTMLNode]
[HTMLRadioBox]^[HTMLNode]

[HTMLTree]-1>[Doctype]
[HTMLTree]-1>[HTMLNode]

// Probably wrong cardinality and relation: to be verified...
[TagNode]-*>[BaseTagNode]
